---
interface Props {
  name: string;
  size?: number;
  class?: string;
}

const { name, size = 24, class: className = '' } = Astro.props;
---

{name === 'brain' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={`icon ${className}`}>
    <path d="M12 2C9 2 7 4 7 6.5C7 5 5.5 4 4 5s-1 3.5 0 5c-1.5 1-2 3-.5 4.5s3 2 4.5 1.5c0 1.5 1.5 3 3.5 3h1" />
    <path d="M12 2c3 0 5 2 5 4.5C17 5 18.5 4 20 5s1 3.5 0 5c1.5 1 2 3 .5 4.5s-3 2-4.5 1.5c0 1.5-1.5 3-3.5 3h-1" />
    <circle cx="8" cy="10" r="1" fill="currentColor" />
    <circle cx="16" cy="10" r="1" fill="currentColor" />
    <circle cx="12" cy="14" r="1" fill="currentColor" />
    <line x1="8" y1="10" x2="12" y2="14" opacity="0.5" />
    <line x1="16" y1="10" x2="12" y2="14" opacity="0.5" />
  </svg>
)}

{name === 'backup' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={`icon ${className}`}>
    <path d="M4 14.899A7 7 0 1 1 15.71 8h1.79a4.5 4.5 0 0 1 2.5 8.242" />
    <path d="M12 12v9" />
    <path d="m8 17 4 5 4-5" />
  </svg>
)}

{name === 'shield' && (
