    <circle cx="16" cy="16" r="2" />
    <line x1="9.5" y1="9.5" x2="14.5" y2="14.5" />
  </svg>
)}

{name === 'vault' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={`icon ${className}`}>
    <rect x="3" y="3" width="18" height="18" rx="3" />
    <circle cx="12" cy="12" r="4" />
    <circle cx="12" cy="12" r="1" fill="currentColor" />
