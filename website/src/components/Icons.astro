    <path d="M12 2L3 7v5c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-9-5z" />
    <path d="m9 12 2 2 4-4" />
  </svg>
)}

{name === 'sync' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={`icon ${className}`}>
    <path d="M21 12a9 9 0 1 1-9-9c2.52 0 4.93 1 6.74 2.74L21 8" />
    <path d="M21 3v5h-5" />
  </svg>
)}

{name === 'search' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={`icon ${className}`}>
    <circle cx="11" cy="11" r="8" />
    <line x1="21" y1="21" x2="16.65" y2="16.65" />
    <circle cx="9" cy="9" r="1" fill="currentColor" />
    <circle cx="13" cy="9" r="1" fill="currentColor" />
    <circle cx="11" cy="13" r="1" fill="currentColor" />
    <line x1="9" y1="9" x2="11" y2="13" opacity="0.4" />
    <line x1="13" y1="9" x2="11" y2="13" opacity="0.4" />
  </svg>
)}

{name === 'connector' && (
  <svg width={size} height={size} viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class={`icon ${className}`}>
    <path d="M15.5 2H18a2 2 0 0 1 2 2v2.5" />
    <path d="M8.5 2H6a2 2 0 0 0-2 2v2.5" />
    <path d="M15.5 22H18a2 2 0 0 0 2-2v-2.5" />
