---
import Layout from '../layouts/Layout.astro';
import { Content as SpecContent } from '../../../spec/omp-v2.0.md';
---

<Layout title="Specification">
  <div class="container section">
    <div class="spec-container max-w-readable">
      <div class="spec-content">
        <SpecContent />
      </div>
    </div>
  </div>
</Layout>

<style is:global>
  .spec-container {
    background: var(--color-surface);
    padding: var(--space-8);
    border-radius: 12px;
    border: 1px solid var(--color-surface-border);
  }

  .spec-content {
    font-size: 1.1rem;
  }

  .spec-content h1 { font-size: 2.5rem; margin-top: var(--space-8); margin-bottom: var(--space-4); color: #fff; }
  .spec-content h2 { font-size: 1.8rem; margin-top: var(--space-8); margin-bottom: var(--space-4); color: #fff; border-bottom: 1px solid var(--color-surface-border); padding-bottom: 0.5rem; }
  .spec-content h3 { font-size: 1.4rem; margin-top: var(--space-6); margin-bottom: var(--space-3); color: #fff; }
  
  .spec-content p { color: var(--color-text); margin-bottom: var(--space-4); line-height: 1.7; }
  
  .spec-content ul, .spec-content ol { margin-bottom: var(--space-4); padding-left: var(--space-6); }
  .spec-content li { color: var(--color-text); margin-bottom: var(--space-2); }
  
  .spec-content table {
    width: 100%;
    border-collapse: collapse;
    margin: var(--space-6) 0;
  }
  
  .spec-content th, .spec-content td {
    padding: 12px 16px;
    text-align: left;
    border: 1px solid var(--color-surface-border);
  }
  
  .spec-content th {
    background: var(--color-surface-hover);
    font-weight: 600;
    color: #fff;
  }

  .spec-content code {
    background: var(--color-surface-hover);
    padding: 0.2em 0.4em;
    border-radius: 4px;
    font-family: var(--font-mono);
    color: var(--color-primary);
  }

  .spec-content pre {
    background: #000;
    padding: var(--space-4);
    border-radius: 8px;
    border: 1px solid var(--color-surface-border);
    overflow-x: auto;
    margin-bottom: var(--space-6);
  }

  .spec-content pre code {
    background: transparent;
    padding: 0;
    color: var(--color-text);
  }

  .spec-content blockquote {
    border-left: 4px solid var(--color-primary);
    padding-left: var(--space-4);
    margin: var(--space-6) 0;
    font-style: italic;
    color: var(--color-text-muted);
  }
</style>
