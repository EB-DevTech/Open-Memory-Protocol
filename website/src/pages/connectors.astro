---
import Layout from '../layouts/Layout.astro';
import Icons from '../components/Icons.astro';

const connectors = [
  {
    name: "ChatGPT",
    status: "Available",
    statusClass: "tag-available",
    type: "Export file converter",
    input: "conversations.json",
    output: ".omp.zip",
    maintainer: "OMP Working Group",
    accentClass: "chatgpt-accent"
  },
  {
    name: "Claude",
    status: "Available",
    statusClass: "tag-available",
    type: "Export file converter",
    input: "claude-export.json",
    output: ".omp.zip",
    maintainer: "OMP Working Group",
    accentClass: "claude-accent"
  },
  {
    name: "Gemini",
    status: "In Progress",
    statusClass: "tag-progress",
    type: "Google Takeout converter",
    input: "Google Takeout",
    output: ".omp.zip",
    maintainer: "Community",
    accentClass: "gemini-accent"
  },
  {
    name: "Cursor",
    status: "In Progress",
    statusClass: "tag-progress",
    type: "SQLite database extractor",
    input: "Local SQLite DB",
    output: ".omp.zip",
    maintainer: "Community",
    accentClass: "cursor-accent"
  },
  {
    name: "Perplexity",
    status: "Planned",
    statusClass: "tag-planned",
    type: "Export file converter",
    input: "Q&A JSON",
    output: ".omp.zip",
    maintainer: "Community",
    accentClass: "perplexity-accent"
  },
  {
    name: "Custom / Local LLMs",
    status: "Planned",
    statusClass: "tag-planned",
    type: "Ollama, LM Studio, Open WebUI adapters",
    input: "Various",
    output: ".omp.zip",
    maintainer: "Community",
    accentClass: "local-accent"
  }
];
---

<Layout
  title="Connector Registry"
  description="Browse the OMP Connector Registry. Connectors translate proprietary AI platform exports into the universal Open Memory Protocol format."
  canonical="https://openmemoryprotocol.com/connectors"
>
  <section class="section">
    <div class="container">
      <div class="text-center max-w-prose mx-auto" data-reveal>
        <p class="section-label">Registry</p>
        <h1>OMP Connectors</h1>
        <p style="margin-top: var(--space-4); font-size: 1.1rem;">
          Connectors translate proprietary platform exports into the universal OMP exchange format. Drop in, convert out.
        </p>
      </div>

      <div class="connectors-grid" data-reveal>
        {connectors.map((c) => (
          <div class={`neural-card connector-card`}>
            <div class="connector-top">
              <h3 class={c.accentClass}>{c.name}</h3>
              <span class={`tag ${c.statusClass}`}>{c.status}</span>
            </div>

            <div class="connector-flow">
              <code class="flow-input">{c.input}</code>
              <Icons name="arrow-right" size={14} class="flow-arrow" />
              <code class="flow-output">{c.output}</code>
            </div>

            <p class="connector-type">{c.type}</p>
            <p class="connector-maintainer">Maintained by <strong>{c.maintainer}</strong></p>

            <a href="https://github.com/EB-DevTech/Open-Memory-Protocol/tree/main/connectors"
               class="btn btn-secondary connector-btn"
               target="_blank" rel="noopener">
              <Icons name="github" size={14} />
              View Source
            </a>
          </div>
        ))}
      </div>

      <div class="neural-card build-cta text-center" data-reveal style="margin-top: var(--space-12); padding: var(--space-10);">
        <div class="icon-hex mx-auto" style="margin-bottom: var(--space-5); width: 56px; height: 56px;">
          <Icons name="connector" size={26} />
        </div>
        <h2>Build a Connector</h2>
        <p class="max-w-prose mx-auto" style="margin-top: var(--space-3); margin-bottom: var(--space-6);">
          Don't see your favorite platform? Anyone can contribute a connector. Our guide walks you through mapping native formats to the OMP schema.
        </p>
        <a href="https://github.com/EB-DevTech/Open-Memory-Protocol/blob/main/CONTRIBUTING.md"
           class="btn btn-primary" target="_blank" rel="noopener">
          Read the Contributing Guide
          <Icons name="arrow-right" size={16} />
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  .section-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-synapse);
    margin-bottom: var(--space-3);
  }

  .connectors-grid {
    display: grid;
    gap: var(--space-6);
    margin-top: var(--space-12);
    grid-template-columns: 1fr;
  }

  @media (min-width: 768px) {
    .connectors-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 1024px) {
    .connectors-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .connector-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .connector-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .connector-top h3 { font-size: 1.25rem; }

  .chatgpt-accent { color: var(--color-chatgpt); }
  .claude-accent { color: var(--color-claude); }
  .gemini-accent { color: var(--color-gemini); }
  .cursor-accent { color: var(--color-axon); }
  .perplexity-accent { color: var(--color-dendrite); }
  .local-accent { color: var(--color-text-bright); }

  .connector-flow {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: var(--space-3) var(--space-4);
    background: rgba(0, 0, 0, 0.3);
    border-radius: var(--radius-sm);
    border: 1px solid rgba(var(--color-synapse-rgb), 0.05);
  }

  .flow-input {
    color: var(--color-text-muted);
    font-size: 0.8rem;
  }

  .flow-arrow {
    color: var(--color-synapse);
    opacity: 0.5;
  }

  .flow-output {
    color: var(--color-synapse);
    font-weight: 600;
    font-size: 0.8rem;
  }

  .connector-type {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .connector-maintainer {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .connector-maintainer strong { color: var(--color-text); }

  .connector-btn {
    margin-top: auto;
    font-size: 0.8rem;
    padding: 0.4rem 0.8rem;
  }
</style>
