{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openmemoryprotocol.com/schemas/v2.0/memory-record.json",
  "title": "OMP Memory Record",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "record_type": {
      "type": "string",
      "enum": ["preference", "fact", "decision", "summary", "entity", "instruction", "custom"]
    },
    "content": { "type": "string" },
    "source_conversations": {
      "type": "array",
      "items": { "type": "string", "format": "uuid" }
    },
    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "expires_at": { "type": "string", "format": "date-time" },
    "supersedes": { "type": "string", "format": "uuid" },
    "platform": { "type": "string" },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "active": { "type": "boolean" }
  },
  "required": ["id", "record_type", "content", "created_at", "updated_at", "active"]
}
